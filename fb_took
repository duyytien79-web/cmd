def is_facebook_session_ready(driver) -> bool:
    """True khi đã có phiên đăng nhập hợp lệ (cookie c_user, không còn login/checkpoint)."""
    try:
        u = driver.current_url.lower()
        if "facebook.com" not in u and "fb.com" not in u:
            return False
        if "checkpoint" in u or "/recover" in u:
            return False
        if "/login" in u or "login.php" in u:
            return False
        for c in driver.get_cookies():
            if c.get("name") == "c_user" and str(c.get("value", "")).strip():
                return True
        return False
    except Exception:
        return False


def _wait_for_facebook_login_worker():
    deadline = time.time() + 1200
    try:
        while time.time() < deadline:
            if LOGIN_WAIT_CANCEL.is_set():
                log("Đã hủy chờ đăng nhập Facebook")
                return
            drv = get_driver()
            if not drv:
                log("Trình duyệt đã đóng trước khi đăng nhập xong")
                return
            try:
                if is_facebook_session_ready(drv):
                    set_logged_in(True)
                    log("Đã đăng nhập Facebook (tự nhận, không cần bấm thêm)")
                    return
            except (InvalidSessionIdException, WebDriverException):
                log("Phiên trình duyệt mất khi đang chờ đăng nhập")
                set_logged_in(False)
                set_driver(None)
                return
            except Exception:
                pass
            time.sleep(2)
        if not is_logged_in():
            log("Hết thời gian chờ đăng nhập (20 phút). Thử bấm lại nút đăng nhập.")
    finally:
        with STATE["lock"]:
            STATE["login_waiting"] = False


def login_facebook_once() -> tuple[bool, str]:
    """
    Một thao tác: mở Facebook (Chrome dùng profile lưu tại chrome_fb_profile),
    tự chờ đến khi phát hiện đăng nhập xong.
    """
    clear_stop()
    with STATE["lock"]:
        if STATE["running"]:
            return False, "Đang chạy job, không thể đăng nhập lúc này"
        if STATE["login_waiting"]:
            drv = STATE["driver"]
            if drv is None:
                # Trạng thái lệch (crash / đóng Chrome giữa chừng): cho phép thử lại.
                STATE["login_waiting"] = False
                LOGIN_WAIT_CANCEL.clear()
            else:
                return False, "Đang chờ bạn đăng nhập trong Chrome — không cần bấm thêm"
        if STATE["logged_in"]:
            drv = STATE["driver"]
            if drv:
                try:
                    if is_facebook_session_ready(drv):
                        return True, "Đã đăng nhập sẵn"
                except Exception:
                    pass

    LOGIN_WAIT_CANCEL.clear()
    try:
        driver = get_driver()
        if not driver:
            driver = init_driver()
            set_driver(driver)
        driver.get("https://www.facebook.com/")
        set_logged_in(False)
    except Exception as e:
        log(f"Không thể mở Facebook: {e}")
        return False, f"Không thể mở Facebook: {e}"

    try:
        if is_facebook_session_ready(get_driver()):
            set_logged_in(True)
            log("Đã đăng nhập sẵn từ profile Chrome (lần trước)")
            return True, "Đã đăng nhập sẵn (profile Chrome)"
    except Exception:
        pass

    log("Đã mở Facebook. Đăng nhập một lần trong cửa sổ Chrome — web sẽ tự nhận khi xong.")
    with STATE["lock"]:
        STATE["login_waiting"] = True
    threading.Thread(target=_wait_for_facebook_login_worker, daemon=True).start()
    return True, "Đã mở Chrome. Đăng nhập xong là xong, không cần bấm thêm nút nào."

# ==================== LOAD GROUPS ====================
def load_groups() -> list[str]:
    """Đọc danh sách group từ file nhom.txt"""
    if not os.path.exists(GROUPS_FILE):
        log(f"❌ File '{GROUPS_FILE}' không tồn tại!")
        return []
    
    try:
        with open(GROUPS_FILE, "r", encoding="utf-8") as f:
            lines = f.readlines()
        
        groups = [line.strip() for line in lines if line.strip() and line.strip().startswith(("http://", "https://"))]
        
        if not groups:
            log(f"❌ Không có group hợp lệ trong '{GROUPS_FILE}'")
            return []
        
        log(f"✔  Tìm thấy {len(groups)} group:")
        for idx, group in enumerate(groups, 1):
            log(f"   {idx}. {group}")
        
        return groups
    
    except Exception as e:
        log(f"❌ Lỗi đọc file '{GROUPS_FILE}': {e}")
        return []

