def post_to_group(
    driver,
    wait: WebDriverWait,
    group_url: str,
    content: str,
    images: list[str],
    *,
    engage_like: bool = False,
    engage_comment: Optional[str] = None,
) -> bool:
    """🚀 QUY TRÌNH POST NHANH - tối ưu từng bước"""
    
    # 1️⃣ VÀO GROUP
    driver.get(group_url)
    time.sleep(random.uniform(2, 3))  # 👈 Giảm từ 6-10s xuống 2-3s
    
    if "login" in driver.current_url:
        log("❌ Hết phiên đăng nhập!")
        return False
    
    # 2️⃣ SCROLL NHẸ
    driver.execute_script("window.scrollTo(0, 200)")
    time.sleep(0.5)  # 👈 Giảm từ 2s xuống 0.5s
    
    # 3️⃣ CLICK TẠO BÀI
    if not click_create_post(driver, wait):
        save_screenshot(driver, "err_create.png")
        return False
    
    # 4️⃣ TÌM TEXTBOX
    post_box = find_post_textbox(driver, wait)
    if post_box is None:
        save_screenshot(driver, "err_textbox.png")
        return False
    
    # 5️⃣ VIẾT NỘI DUNG + UPLOAD ẢNH SONG SONG
    try:
        type_content(post_box, content)
        upload_images(driver, wait, images)
    except Exception as e:
        log(f"❌ Lỗi: {e}")
        return False
    
    # 6️⃣ ĐĂNG BÀI (nếu sẽ like/comment: chờ ngắn hơn rồi tương tác ngay trên feed)
    will_engage = bool(engage_like or (engage_comment and engage_comment.strip()))
    after_sleep = 1.05 if will_engage else 3.0
    if not click_post_button(driver, wait, after_click_sleep=after_sleep):
        time.sleep(0.6)  # 👈 cho bài xuất hiện trên feed
        save_screenshot(driver, "err_post.png")
        return False
    
    log("✅ THÀNH CÔNG")
    if will_engage:
        engage_with_fresh_post(driver, wait, group_url, content, engage_like, engage_comment)
    return True


