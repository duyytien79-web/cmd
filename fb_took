def upload_images(driver, wait: WebDriverWait, images: list[str]):
    """
    Upload ảnh SONG SONG - gửi tất cả ảnh một lúc thay vì từng cái
    Nhanh gấp 3-4 lần so với cách gửi từng ảnh
    """
    if not images:
        log("⚠️  Không có ảnh để upload")
        return

    valid_images = [p for p in images if os.path.exists(p)]
    if not valid_images:
        log("❌ Không có file ảnh hợp lệ")
        return

    log(f"📤 Upload {len(valid_images)} ảnh...")

    try:
        # 🚀 TÌM INPUT FILE
        fi = wait.until(EC.presence_of_element_located((
            By.XPATH,
            "//div[@role='dialog']//input[@type='file']"
        )))
        
        # 🚀 BỎ CSS XEM BẤT MÀN HÌNH
        driver.execute_script("""
            arguments[0].style.display = 'block';
            arguments[0].style.visibility = 'visible';
            arguments[0].style.opacity = '1';
            arguments[0].style.pointerEvents = 'auto';
            arguments[0].removeAttribute('class');
        """, fi)
        
        time.sleep(0.3)  # 👈 Giảm từ 4s xuống 0.3s
        
        # 🚀 GỬI TẤT CẢ ẢNH CỘT LỌC (SONG SONG)
        file_paths = "\n".join(valid_images)
        fi.send_keys(file_paths)
        
        log(f"✅ Gửi {len(valid_images)} ảnh")
        
        # 🚀 CHỜ ẢNH RENDER (giảm từ 6-9s xuống 2-4s)
        time.sleep(random.uniform(2, 4))
        
    except Exception as e:
        log(f"⚠️  Lỗi upload ảnh: {str(e)[:60]}")


def click_post_button(driver, wait: WebDriverWait, after_click_sleep: float = 3.0) -> bool:
    """
    Click nút 'Đăng' - không chờ lâu.
    after_click_sleep: chờ sau khi đăng (khi sẽ like/comment ngay thì dùng ~1s).
    """
    # 🚀 GIẢM TIMEOUT từ 15s xuống 8s
    try:
        wait_enabled = WebDriverWait(driver, 8)
        post_btn = wait_enabled.until(
            EC.element_to_be_clickable((
                By.XPATH,
                "//div[@aria-label='Đăng' and not(@aria-disabled='true')]"
                "| //div[@aria-label='Post' and not(@aria-disabled='true')]"
            ))
        )
        driver.execute_script("arguments[0].click();", post_btn)
        log("🚀 Đăng bài")
        time.sleep(after_click_sleep)
        return True
    except Exception:
        pass

    # Fallback
    try:
        post_btn = wait.until(EC.element_to_be_clickable((
            By.XPATH,
            "//div[@role='dialog']//div[@role='button'][.//span[text()='Đăng']]"
            "| //div[@role='dialog']//div[@role='button'][.//span[text()='Post']]"
        )))
        driver.execute_script("arguments[0].click();", post_btn)
        log("🚀 Đăng bài (cách 2)")
        time.sleep(after_click_sleep)
        return True
    except Exception as e:
        log(f"❌ Lỗi click nút đăng: {str(e)[:60]}")
        return False


