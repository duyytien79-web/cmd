# ==================== LOGGING ====================
def log(msg: str):
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{timestamp}] {msg}"
    try:
        print(line)
    except UnicodeEncodeError:
        # Fallback for Windows terminals with limited codepage support.
        safe_line = line.encode("cp1258", errors="replace").decode("cp1258", errors="replace")
        print(safe_line)
    with open(LOG_FILE, "a", encoding="utf-8") as f:
        f.write(line + "\n")
    with STATE["lock"]:
        STATE["logs"].append(line)
        if len(STATE["logs"]) > 300:
            STATE["logs"] = STATE["logs"][-300:]

def generate_content() -> str:
    return BASE_CONTENT


def get_driver():
    with STATE["lock"]:
        return STATE["driver"]


def set_driver(driver):
    with STATE["lock"]:
        STATE["driver"] = driver


def is_logged_in() -> bool:
    with STATE["lock"]:
        return STATE["logged_in"]


def set_logged_in(value: bool):
    with STATE["lock"]:
        STATE["logged_in"] = value


def request_stop():
    with STATE["lock"]:
        STATE["stop_requested"] = True


def clear_stop():
    with STATE["lock"]:
        STATE["stop_requested"] = False


def should_stop() -> bool:
    with STATE["lock"]:
        return STATE["stop_requested"]


def close_driver():
    LOGIN_WAIT_CANCEL.set()
    driver = get_driver()
    if not driver:
        with STATE["lock"]:
            STATE["login_waiting"] = False
        LOGIN_WAIT_CANCEL.clear()
        set_logged_in(False)
        return
    try:
        driver.quit()
    except Exception:
        pass
    set_driver(None)
    set_logged_in(False)
    with STATE["lock"]:
        STATE["login_waiting"] = False
    LOGIN_WAIT_CANCEL.clear()


