def _extract_phone(content: str) -> Optional[str]:
    import re
    nums = re.findall(r'\d{9,11}', content)
    return nums[0] if nums else None


def _find_post_article(driver, content: str):
    """Tìm bài của mình = SĐT + bài mới nhất"""
    phone = _extract_phone(content)

    try:
        articles = driver.find_elements(By.XPATH, "//div[@role='article']")
    except Exception:
        return None

    if not articles or not phone:
        return None

    # 🎯 chỉ lấy các bài mới nhất
    recent_articles = articles[:10]

    for art in recent_articles:
        try:
            text = (art.text or "").replace("\n", " ").strip()
            if phone in text:
                return art  # ✅ đúng bài của bạn
        except Exception:
            continue

    return None


