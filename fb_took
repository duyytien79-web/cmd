def click_create_post(driver, wait: WebDriverWait) -> bool:
    """Tìm và click nút 'Tạo bài viết' / 'Bạn viết gì đi'."""
    xpaths = [
        "//div[@role='button'][.//span[contains(text(), 'Bạn viết gì đi')]]",
        "//*[contains(text(), 'Bạn viết gì đi')]//ancestor::div[@role='button']",
