def get_images() -> list[str]:
    if not os.path.exists(IMAGE_FOLDER):
        log(f"❌ Thư mục '{IMAGE_FOLDER}' không tồn tại!")
        return []

    exts = (".jpg", ".jpeg", ".png", ".webp")
