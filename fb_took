def _recover_driver_for_web_job() -> tuple[Optional[webdriver.Chrome], Optional[WebDriverWait]]:
    """
    Tạo lại driver khi phiên cũ bị rớt. Ưu tiên dùng profile đã lưu để tự nhận đăng nhập lại.
    """
    try:
        old = get_driver()
        if old:
            try:
                old.quit()
            except Exception:
                pass
    except Exception:
        pass

    set_driver(None)
    set_logged_in(False)
    LOGIN_WAIT_CANCEL.clear()

    try:
        new_driver = init_driver()
        set_driver(new_driver)
        new_wait = WebDriverWait(new_driver, 15)
        new_driver.get("https://www.facebook.com/")
        time.sleep(1.0)
        if is_facebook_session_ready(new_driver):
            set_logged_in(True)
            log("✅ Đã khôi phục phiên Chrome và nhận đăng nhập từ profile")
            return new_driver, new_wait
        log("❌ Khôi phục driver xong nhưng chưa có phiên Facebook đăng nhập")
        return None, None
    except Exception as e:
        log(f"❌ Không thể khôi phục driver: {e}")
        return None, None


def run_post_job(
    groups: list[str],
    content: str,
    delay_from: int,
    delay_to: int,
    use_uploaded_images: bool,
    engage_like: bool = False,
    engage_comment: Optional[str] = None,
):
    """Run posting flow in background for web mode."""
    with STATE["lock"]:
        STATE["running"] = True

    try:
        if not groups:
            log("❌ Danh sách group trống, dừng job")
            return

        driver = get_driver()
        if not driver:
            log("❌ Chưa có phiên đăng nhập. Hãy đăng nhập trước.")
            return

        wait = WebDriverWait(driver, 15)
        if not is_logged_in():
            log("❌ Bạn chưa đăng nhập Facebook.")
            return

        images = get_uploaded_images() if use_uploaded_images else get_images()
        if use_uploaded_images:
            log(f"🖼️ Dùng {len(images)} ảnh đã upload từ web")
        if engage_like or (engage_comment and engage_comment.strip()):
            log("ℹ️ Đã bật: sau mỗi bài sẽ tự like và/hoặc bình luận (nếu Facebook hiển thị đúng)")

        for idx, group_url in enumerate(groups):
            if should_stop():
                log("⏹️ Đã nhận yêu cầu dừng job.")
                break

            log(f"\n{'=' * 50}")
            log(f"📌 Group {idx + 1}/{len(groups)}")
            log(f"{'=' * 50}")

            success = False
            retried_after_recover = False
            while True:
                try:
                    success = post_to_group(
                        driver,
                        wait,
                        group_url,
                        content,
                        images,
                        engage_like=engage_like,
                        engage_comment=engage_comment,
                    )
                    break
                except (InvalidSessionIdException, WebDriverException) as e:
                    if retried_after_recover:
                        log(f"❌ Mất phiên lần 2 ở group {idx + 1}: {e}")
                        raise
                    log(f"⚠️ Mất phiên trình duyệt ở group {idx + 1}, đang tự khôi phục: {e}")
                    new_driver, new_wait = _recover_driver_for_web_job()
                    if not new_driver or not new_wait:
                        log("❌ Không khôi phục được phiên trình duyệt, dừng job.")
                        raise
                    driver, wait = new_driver, new_wait
                    retried_after_recover = True
                    log(f"🔁 Thử lại group {idx + 1} sau khi khôi phục phiên...")

            if not success:
                log(f"⚠️  Bỏ qua group {idx + 1}")

            if idx < len(groups) - 1:
                delay = random.randint(delay_from, delay_to)
                log(f"⏳ Chờ {delay}s...")
                for _ in range(delay):
                    if should_stop():
                        log("⏹️ Dừng trong lúc delay.")
                        break
                    time.sleep(1)
                if should_stop():
                    break
    except (InvalidSessionIdException, WebDriverException) as e:
        log(f"❌ Phiên trình duyệt đã mất: {e}")
        set_logged_in(False)
        set_driver(None)
    except Exception as e:
        log(f"❌ Lỗi job nền: {e}")
    finally:
        with STATE["lock"]:
            STATE["running"] = False
            STATE["worker"] = None
            STATE["stop_requested"] = False
        log("🎉 Hoàn thành job từ frontend")


class AppHandler(BaseHTTPRequestHandler):
    @staticmethod
    def _norm_path(raw: str) -> str:
        """Path gốc có thể kèm ?query — nếu không chuẩn hóa thì POST /api/login-once?s=1 sẽ 404."""
        p = raw.split("?", 1)[0].split("#", 1)[0]
        return p

    def _send_json(self, data: dict, status: int = 200):
        body = json.dumps(data, ensure_ascii=False).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _send_html(self, html: str, status: int = 200):
        body = html.encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        path = self._norm_path(self.path)
        if path in ("/", "/index.html"):
            if not HTML_FILE.exists():
                self._send_html("<h1>main.html not found</h1>", 404)
                return
            self._send_html(HTML_FILE.read_text(encoding="utf-8"))
            return

        if path == "/api/status":
            with STATE["lock"]:
                data = {
                    "running": STATE["running"],
                    "logged_in": STATE["logged_in"],
                    "login_waiting": STATE["login_waiting"],
                    "stop_requested": STATE["stop_requested"],
                    "uploaded_count": len(STATE["uploaded_images"]),
                    "logs": STATE["logs"][-80:],
                }
            self._send_json(data)
            return
        if path == "/api/groups":
            self._send_json({"groups": load_groups()})
            return

        self._send_json({"error": "Not found"}, 404)

    def do_POST(self):
        path = self._norm_path(self.path)
        if path not in (
            "/api/start",
            "/api/login-once",
            "/api/stop",
            "/api/logout",
            "/api/groups",
            "/api/upload",
        ):
            self._send_json({"error": "Not found"}, 404)
            return

        if path == "/api/upload":
            ctype = self.headers.get("Content-Type", "")
            if not ctype.startswith("multipart/form-data"):
                self._send_json({"error": "Yêu cầu phải là multipart/form-data"}, 400)
                return

            form = cgi.FieldStorage(
                fp=self.rfile,
                headers=self.headers,
                environ={"REQUEST_METHOD": "POST", "CONTENT_TYPE": ctype},
            )
            files = form["files"] if "files" in form else []
            if not isinstance(files, list):
                files = [files]

            UPLOAD_DIR.mkdir(parents=True, exist_ok=True)
            allowed_exts = {".jpg", ".jpeg", ".png", ".webp"}
            saved_paths: list[str] = []

            for f in files:
                if not getattr(f, "filename", None):
                    continue
                ext = Path(f.filename).suffix.lower()
                if ext not in allowed_exts:
                    continue
                safe_name = f"{int(time.time() * 1000)}_{os.path.basename(f.filename)}"
                dest = UPLOAD_DIR / safe_name
                data = f.file.read()
                with open(dest, "wb") as out:
                    out.write(data)
                saved_paths.append(str(dest.resolve()))

            if not saved_paths:
                self._send_json({"error": "Không có ảnh hợp lệ để upload"}, 400)
                return

            set_uploaded_images(saved_paths)
            log(f"✅ Đã upload {len(saved_paths)} ảnh từ giao diện web")
            self._send_json({"ok": True, "count": len(saved_paths), "paths": saved_paths})
            return

        length = int(self.headers.get("Content-Length", "0"))
        try:
            payload = json.loads(self.rfile.read(length).decode("utf-8") or "{}")
        except json.JSONDecodeError:
            self._send_json({"error": "JSON không hợp lệ"}, 400)
            return
  
        if path == "/api/login-once":
            try:
                ok, message = login_facebook_once()
            except Exception as e:
                log(f"Lỗi /api/login-once: {e}")
                self._send_json({"ok": False, "error": str(e)}, 500)
                return
            self._send_json({"ok": ok, "message": message}, 200 if ok else 400)
            return

        if path == "/api/logout":
            with STATE["lock"]:
                if STATE["running"]:
                    self._send_json({"error": "Đang chạy job, không thể logout."}, 409)
                    return
            close_driver()
            log("ℹ️ Đã logout phiên Facebook")
            self._send_json({"ok": True, "message": "Đã logout"})
            return

        if path == "/api/stop":
            with STATE["lock"]:
                if not STATE["running"]:
                    STATE["stop_requested"] = False
                    self._send_json({"ok": True, "message": "Hiện không có job nào đang chạy"})
                    return
            request_stop()
            self._send_json({"ok": True, "message": "Đã gửi yêu cầu dừng"})
            return

        if path == "/api/groups":
            groups = payload.get("groups", [])
            if not isinstance(groups, list):
                self._send_json({"error": "groups phải là mảng"}, 400)
                return
            clean_groups = [g.strip() for g in groups if isinstance(g, str) and g.strip()]
            save_groups(clean_groups)
            self._send_json({"ok": True, "count": len(clean_groups)})
            return

        with STATE["lock"]:
            if STATE["running"]:
                self._send_json({"error": "Đang có job chạy, vui lòng chờ."}, 409)
                return

        groups = payload.get("groups") or load_groups()
        if not isinstance(groups, list):
            self._send_json({"error": "groups phải là mảng URL"}, 400)
            return
        groups = [g.strip() for g in groups if isinstance(g, str) and g.strip()]
        if not groups:
            self._send_json({"error": "Vui lòng nhập ít nhất 1 group URL"}, 400)
            return
        if not is_logged_in():
            self._send_json({"error": "Bạn chưa đăng nhập Facebook trên web."}, 401)
            return

        content = (payload.get("content") or BASE_CONTENT).strip() or BASE_CONTENT
        delay_from = int(payload.get("delay_from", POST_DELAY_MIN))
        delay_to = int(payload.get("delay_to", POST_DELAY_MAX))
        use_uploaded_images = bool(payload.get("use_uploaded_images", False))
        engage_like = bool(payload.get("engage_like", False))
        engage_comment_raw = payload.get("engage_comment")
        engage_comment: Optional[str] = None
        if engage_comment_raw is not None and str(engage_comment_raw).strip():
            engage_comment = str(engage_comment_raw).strip()
        if delay_from < 1:
            delay_from = 1
        if delay_to < delay_from:
            delay_to = delay_from

        clear_stop()
        worker = threading.Thread(
            target=run_post_job,
            args=(groups, content, delay_from, delay_to, use_uploaded_images, engage_like, engage_comment),
            daemon=True,
        )
        with STATE["lock"]:
            STATE["worker"] = worker
        worker.start()
        self._send_json({"ok": True, "message": "Đã bắt đầu job"})

    def log_message(self, format, *args):
        return


def run_web_server(host: str = "127.0.0.1", port: int = 8000):
    server = ThreadingHTTPServer((host, port), AppHandler)
    log(f"🌐 Web UI: http://{host}:{port}")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        log("⏹️ Dừng web server")
    finally:
        server.server_close()


