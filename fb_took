def _top_feed_article(driver):
    """
    Bài đầu feed (không nằm trong dialog). Sau khi đăng, Facebook thường chèn bài mới lên đầu —
    dùng luôn để like/comment ngay, không chờ quét khớp nội dung.
    """
    try:
        el = driver.execute_script(
            """
            const arts = document.querySelectorAll('div[role="article"]');
            for (const art of arts) {
                if (art.offsetParent === null) continue;
                let p = art;
                let inDlg = false;
                while (p) {
                    if (p.getAttribute && p.getAttribute('role') === 'dialog') {
                        inDlg = true;
                        break;
                    }
                    p = p.parentElement;
                }
                if (inDlg) continue;
                const t = (art.innerText || '').trim();
                if (t.length < 3) continue;
                return art;
            }
            return null;
            """
        )
        return el
    except Exception:
        return None


def _click_like_on_article(driver, article) -> bool:
    def _norm(s: str) -> str:
        s = (s or "").strip().lower()
        s = "".join(ch for ch in unicodedata.normalize("NFD", s) if unicodedata.category(ch) != "Mn")
        return " ".join(s.split())

    include_keys = (
        "like",
        "thich",
        "yeu thich",
        "love",
        "reaction",
        "cam xuc",
    )
    exclude_keys = (
        "comment",
        "binh luan",
        "share",
        "chia se",
        "gui",
        "send",
    )
    already_liked_keys = ("da thich", "liked", "you liked this")

    candidates = []
    try:
        candidates = article.find_elements(By.XPATH, ".//*[@role='button' or self::button]")
    except Exception:
        pass

    for b in candidates:
        try:
            if not b.is_displayed():
                continue
            label = _norm(b.get_attribute("aria-label") or "")
            text = _norm(b.text or "")
            testid = _norm(b.get_attribute("data-testid") or "")
            title = _norm(b.get_attribute("title") or "")
            merged = " ".join(x for x in (label, text, testid, title) if x)
            if not merged:
                continue
            if any(k in merged for k in exclude_keys):
                continue
            if any(k in merged for k in already_liked_keys):
                return True
            if not any(k in merged for k in include_keys):
                continue
            driver.execute_script("arguments[0].scrollIntoView({block:'center'});", b)
            time.sleep(0.1)
            driver.execute_script("arguments[0].click();", b)
            return True
        except Exception:
            continue
    return False


def _submit_comment_on_article(driver, wait: WebDriverWait, article, comment_text: str) -> bool:
    def _norm(s: str) -> str:
        s = (s or "").strip().lower()
        s = "".join(ch for ch in unicodedata.normalize("NFD", s) if unicodedata.category(ch) != "Mn")
        return " ".join(s.split())

    trigger_include_keys = (
        "comment",
        "binh luan",
        "viet binh luan",
        "write a comment",
        "public comment",
    )
    trigger_exclude_keys = ("share", "chia se", "like", "thich", "reaction", "cam xuc")

    comment_triggers = [
        ".//*[@role='button' or self::button]",
    ]
    opened = False
    for xp in comment_triggers:
        try:
            els = article.find_elements(By.XPATH, xp)
            for el in els:
                try:
                    if not el.is_displayed():
                        continue
                    label = _norm(el.get_attribute("aria-label") or "")
                    text = _norm(el.text or "")
                    title = _norm(el.get_attribute("title") or "")
                    merged = " ".join(x for x in (label, text, title) if x)
                    if not merged:
                        continue
                    if any(k in merged for k in trigger_exclude_keys):
                        continue
                    if not any(k in merged for k in trigger_include_keys):
                        continue
                    driver.execute_script("arguments[0].scrollIntoView({block:'center'});", el)
                    time.sleep(0.1)
                    driver.execute_script("arguments[0].click();", el)
                    opened = True
                    break
                except Exception:
                    continue
            if opened:
                break
        except Exception:
            continue

    if not opened:
        try:
            inline = article.find_elements(
                By.XPATH,
                ".//div[@contenteditable='true'][contains(@aria-placeholder,'bình luận') "
                "or contains(@aria-placeholder,'comment') or contains(@aria-placeholder,'viết')]",
            )
            if inline:
                opened = True
        except Exception:
            pass

    time.sleep(0.35)
    short = WebDriverWait(driver, 10)
    box = None
    try:
        boxes = article.find_elements(By.XPATH, ".//div[@contenteditable='true']")
        for b in boxes:
            if b.is_displayed():
                box = b
                break
    except Exception:
        pass
    if box is None:
        box_xpaths = [
            "//div[@role='dialog']//div[@contenteditable='true']",
            "//form//div[@contenteditable='true']",
            "//div[@contenteditable='true'][@data-lexical-editor='true']",
            "//div[@contenteditable='true'][contains(@aria-placeholder,'bình luận')]",
            "//div[@contenteditable='true'][contains(@aria-placeholder,'Comment')]",
            "//div[@contenteditable='true'][contains(@aria-placeholder,'Viết bình luận')]",
            "//div[@contenteditable='true'][contains(@aria-label,'comment')]",
            "//div[@role='textbox' and @contenteditable='true']",
        ]
        for xp in box_xpaths:
            try:
                el = short.until(EC.presence_of_element_located((By.XPATH, xp)))
                if el and el.is_displayed():
                    box = el
                    break
            except Exception:
                continue
    if box is None:
        return False

    try:
        driver.execute_script("arguments[0].scrollIntoView({block:'center'});", box)
        time.sleep(0.1)
        box.click()
        time.sleep(0.1)
        box.send_keys(comment_text)
        time.sleep(0.2)
        box.send_keys(Keys.ENTER)
        time.sleep(0.25)
    except Exception:
        try:
            box.send_keys(Keys.CONTROL + Keys.ENTER)
            time.sleep(0.25)
        except Exception:
            return False

    try:
        submit_btns = driver.find_elements(
            By.XPATH,
            "//div[@role='button'][@aria-label='Comment' or @aria-label='Bình luận' or @aria-label='Post']"
            "| //div[@role='button'][.//span[text()='Bình luận'] or .//span[text()='Comment']]",
        )
        for sb in submit_btns[-3:]:
            try:
                if sb.is_displayed():
                    driver.execute_script("arguments[0].click();", sb)
                    break
            except Exception:
                continue
    except Exception:
        pass

    time.sleep(0.45)
    return True


